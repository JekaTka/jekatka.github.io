# ── Next.js source (inside /nextjs) ───────────────────────
nextjs/node_modules
nextjs/.pnp
nextjs/.pnp.*
nextjs/.yarn/*
!nextjs/.yarn/patches
!nextjs/.yarn/plugins
!nextjs/.yarn/releases
!nextjs/.yarn/versions

# Next.js build output & cache
nextjs/.next/
nextjs/out/

# Testing
nextjs/coverage

# Production builds
nextjs/build

# TypeScript
nextjs/*.tsbuildinfo
nextjs/next-env.d.ts

# ── Misc ───────────────────────────────────────────────────
.DS_Store
*.pem
.env*
.vercel

# Debug logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
